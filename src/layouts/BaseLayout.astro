---
export interface Props {
  title: string;
  lang?: string;
  allSectionsData?: any;
  description?: string;
  canonicalUrl?: string;
  hreflangUrls?: Array<{ hreflang: string; url: string }>;
  structuredData?: object[];
}

const { title, lang = 'de', allSectionsData, description, canonicalUrl, hreflangUrls, structuredData } = Astro.props;

const OG_LOCALES: Record<string, string> = { de: 'de_CH', fr: 'fr_CH', it: 'it_CH' };
const ogLocale = OG_LOCALES[lang] ?? 'de_CH';
const ogLocaleAlternates = Object.entries(OG_LOCALES)
  .filter(([locale]) => locale !== lang)
  .map(([, value]) => value);

import '../styles/global.css';
import '../styles/colors.css';
import '../styles/layout.css';
import PWAUpdatePrompt from '../components/PWAUpdatePrompt.astro';
import { ClientRouter } from 'astro:transitions';
import { absoluteUrl } from '../utils/urls';
import fontRegular from '../styles/fonts/SourceSansPro-Regular.woff2';
import fontBold from '../styles/fonts/SourceSansPro-Bold.woff2';

// Collect the current locale's unique section icon URLs for preloading
const iconUrls: string[] = [];
for (const section of allSectionsData?.sections?.[lang] ?? []) {
  if (section.icon?.url && !iconUrls.includes(section.icon.url)) {
    iconUrls.push(section.icon.url);
  }
}

// The all-sections meta only feeds the client-side language switcher, so
// strip it down to the fields that lookup needs (see languageSwitcher.ts)
let allSectionsMeta: string | null = null;
if (allSectionsData) {
  const sections = Object.fromEntries(
    Object.entries(allSectionsData.sections as Record<string, any[]>).map(([locale, list]) => [
      locale,
      list.map(section => ({
        id: section.id,
        slug: section.slug,
        chapters: (section.chapters ?? []).map((chapter: any) => ({
          slug: chapter.slug,
          sorting: chapter.sorting,
        })),
      })),
    ])
  );
  const mappings = Object.fromEntries(
    Object.entries(allSectionsData.sectionMappings as Record<string, Record<string, any>>).map(
      ([id, localeMap]) => [
        id,
        Object.fromEntries(
          Object.entries(localeMap).map(([locale, entry]) => [
            locale,
            { slug: entry.slug, url: entry.url },
          ])
        ),
      ]
    )
  );
  allSectionsMeta = JSON.stringify({ sections, mappings });
}
---

<!DOCTYPE html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="color-scheme" content="light dark" />
    <script is:inline>
      // Apply the stored theme before first paint to avoid a light flash
      (function () {
        try {
          var theme = localStorage.getItem('thilo-theme') || 'sync';
          var dark = theme === 'dark' ||
            (theme === 'sync' && window.matchMedia('(prefers-color-scheme: dark)').matches);
          if (dark) document.documentElement.classList.add('dark');
        } catch (e) { /* storage unavailable: stay light */ }
      })();
    </script>

    <!-- Preconnect to API and CDN -->
    <link rel="preconnect" href="https://api.thilo.scouts.ch" crossorigin />
    <link rel="dns-prefetch" href="https://api.thilo.scouts.ch" />
    <link rel="preconnect" href="https://res.cloudinary.com" crossorigin />
    <link rel="dns-prefetch" href="https://res.cloudinary.com" />

    <!-- Preload the two above-the-fold font weights -->
    <link rel="preload" href={fontRegular} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={fontBold} as="font" type="font/woff2" crossorigin />

    <!-- Preload section icons -->
    {iconUrls.map(url => (
      <link rel="preload" href={url} as="image" />
    ))}

    <meta name="theme-color" content="#521d3a" />
    <link rel="icon" type="image/x-icon" href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/favicon.ico`} />
    <link rel="apple-touch-icon"         href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/apple-touch-icon.png`} />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="Thilo" />
    <meta name="base-url" content={import.meta.env.BASE_URL.replace(/\/$/, '')} />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Thilo" />
    <meta property="og:title" content={title} />
    <meta property="og:locale" content={ogLocale} />
    {ogLocaleAlternates.map(locale => (
      <meta property="og:locale:alternate" content={locale} />
    ))}
    <meta property="og:image" content={absoluteUrl('/pwa-512.png')} />
    <meta property="og:image:width" content="512" />
    <meta property="og:image:height" content="512" />
    {description && <meta property="og:description" content={description} />}
    {canonicalUrl && <meta property="og:url" content={canonicalUrl} />}
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
    <meta name="twitter:card" content="summary" />
    {hreflangUrls?.map(({ hreflang, url }) => (
      <link rel="alternate" hreflang={hreflang} href={url} />
    ))}
    {structuredData?.map(entry => (
      <script type="application/ld+json" set:html={JSON.stringify(entry)} />
    ))}
    <ClientRouter />
    {allSectionsMeta && <meta name="all-sections" content={allSectionsMeta} />}
  </head>
  <body>
    <slot />
    <PWAUpdatePrompt locale={lang} />
  </body>
</html>

<script>
  import {
    getProgress,
    isChapterRead,
    markChapterRead,
    getSectionReadCount,
    onProgressChange,
    PROGRESS_EVENT,
  } from '../utils/progress';

  // Progress API for inline scripts (e.g. the persisted ToC) and future
  // gamification UI; see docs/GAMIFICATION.md
  (window as any).thiloProgress = {
    getProgress,
    isChapterRead,
    markChapterRead,
    getSectionReadCount,
    onProgressChange,
  };
  // Inline scripts may have run before this module: let listeners re-decorate
  window.dispatchEvent(new CustomEvent(PROGRESS_EVENT));

  // Mark a chapter as read once its heading is fully visible. The heading is
  // observed instead of the chapter div because tall chapters never reach a
  // meaningful intersection ratio.
  function setupReadTracking(): void {
    (window as any).__readObserver?.disconnect();
    const headings = document.querySelectorAll('section.content .chapter > h2');
    if (headings.length === 0) return;

    const base = document.querySelector('meta[name="base-url"]')?.getAttribute('content') ?? '';
    let path = window.location.pathname;
    if (base && path.startsWith(base)) path = path.slice(base.length);
    path = path.replace(/^\/(fr|it)(?=\/|$)/, '');
    const sectionSlug = path.replace(/\/$/, '').split('/').pop() ?? '';
    if (!sectionSlug) return;

    const observer = new IntersectionObserver(entries => {
      for (const entry of entries) {
        if (!entry.isIntersecting) continue;
        const chapterSlug = (entry.target.closest('.chapter') as HTMLElement | null)?.id;
        if (chapterSlug) markChapterRead(sectionSlug, chapterSlug);
        observer.unobserve(entry.target);
      }
    }, { threshold: 1 });
    headings.forEach(heading => observer.observe(heading));
    (window as any).__readObserver = observer;
  }

  function applyColor(): void {
    const el = document.querySelector('section.content') as HTMLElement | null;
    const color = el?.dataset?.color;
    if (color) {
      document.documentElement.style.setProperty('--color-primary', color);
      // Tint the browser/PWA chrome to match the section
      document.querySelector('meta[name="theme-color"]')?.setAttribute('content', color);
    }
  }

  // Scroll an anchor target into view without the content shifting under the
  // user: images above the target are forced to load first (lazy ones are
  // flipped to eager), with a timeout so a stalled image can't block forever.
  function scrollToAnchor(el: HTMLElement, behavior: ScrollBehavior): void {
    const pending = (Array.from(document.querySelectorAll('section.content img')) as HTMLImageElement[])
      .filter(img => !img.complete && (img.compareDocumentPosition(el) & Node.DOCUMENT_POSITION_FOLLOWING));
    pending.forEach(img => { if (img.loading === 'lazy') img.loading = 'eager'; });
    if (pending.length === 0) {
      el.scrollIntoView({ behavior, block: 'start' });
      return;
    }
    const settled = Promise.all(pending.map(img => new Promise<void>(resolve => {
      img.addEventListener('load',  () => resolve(), { once: true });
      img.addEventListener('error', () => resolve(), { once: true });
    })));
    const timeout = new Promise<void>(resolve => setTimeout(resolve, 3000));
    Promise.race([settled, timeout]).then(() => el.scrollIntoView({ behavior, block: 'start' }));
  }
  (window as any).thiloScrollToAnchor = scrollToAnchor;

  function applyStoredTheme(): void {
    let theme = 'sync';
    try { theme = localStorage.getItem('thilo-theme') || 'sync'; } catch { /* stay light */ }
    const dark = theme === 'dark' ||
      (theme === 'sync' && window.matchMedia('(prefers-color-scheme: dark)').matches);
    document.documentElement.classList.toggle('dark', dark);
  }
  (window as any).thiloApplyStoredTheme = applyStoredTheme;

  // View transitions replace <html> attributes, dropping the .dark class
  document.addEventListener('astro:after-swap', applyStoredTheme);
  window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', applyStoredTheme);

  // Smooth-scroll in-content anchor links (e.g. markdown "[see below](#knoten)")
  document.addEventListener('click', (e) => {
    const anchor = (e.target as HTMLElement).closest?.('section.content a[href^="#"]') as HTMLAnchorElement | null;
    if (!anchor) return;
    const id = decodeURIComponent(anchor.getAttribute('href')!.slice(1));
    const target = document.getElementById(id);
    if (!target) return;
    e.preventDefault();
    history.pushState(null, '', '#' + id);
    scrollToAnchor(target, 'smooth');
  });

  function setupBackToTop(): void {
    (window as any).__sectionController?.abort();
    const ctrl = new AbortController();
    (window as any).__sectionController = ctrl;
    const btn = document.getElementById('back-to-top');
    if (!btn) return;
    window.addEventListener('scroll', () => {
      const past = window.scrollY > 300;
      btn.classList.toggle('opacity-0', !past);
      btn.classList.toggle('opacity-100', past);
    }, { signal: ctrl.signal });
  }

  // Apply color immediately after the DOM swap so the transition animation
  // already shows the new section color while it's still animating.
  document.addEventListener('astro:after-swap', applyColor);

  // astro:page-load fires on initial load AND after every navigation.
  // Handles the initial-load case (astro:after-swap doesn't fire then)
  // and resets the back-to-top listener for the new page's button element.
  document.addEventListener('astro:page-load', () => {
    applyColor();
    setupBackToTop();
    setupReadTracking();
  });
</script>
