---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import TableOfContents from '../components/TableOfContents.astro';
import { getSections } from '../utils/data';
import { fetchAllSections } from '../utils/sectionMappings';

export interface Props {
  title: string;
  lang?: string;
  currentSection?: any;
  useFooter?: boolean;
  sections?: any[];
}

const { title, lang = 'de', currentSection, useFooter=true, sections: providedSections } = Astro.props;

let sections: any[] = [];
let allSectionsData: any = null;
try {
  // Fetch all sections data once (includes all locales)
  allSectionsData = await fetchAllSections();
  
  // Use provided sections if available, otherwise extract from allSectionsData
  if (providedSections) {
    sections = providedSections;
  } else if (allSectionsData.sections[lang]) {
    // Convert SimpleSectionsData format to SectionT format
    sections = allSectionsData.sections[lang];
  } else {
    // Fallback to getSections if needed
    sections = await getSections(lang);
  }
} catch (e) {
  console.error('Error loading sections:', e);
  sections = [];
  allSectionsData = { sections: {}, sectionMappings: {} };
}
---

<BaseLayout title={title} lang={lang} allSectionsData={allSectionsData}>
  <Header locale={lang as 'de' | 'fr' | 'it'} currentSection={currentSection} transition:persist />
  
  <div class="flex min-h-[calc(100vh-52px)] w-full max-w-[1400px] mx-auto">
    <!-- Table of Contents Sidebar -->
    <TableOfContents 
      sections={sections} 
      currentSection={currentSection}
      lang={lang}
      transition:persist
    />
    
    <!-- Main Content -->
    <main class="flex-1 overflow-x-hidden min-w-0">
      <div class="px-4 lg:px-10 py-8 max-w-3xl">
        <slot />
        {useFooter &&
          <Footer locale={lang as 'de' | 'fr' | 'it'} currentSection={currentSection} sections={sections} transition:persist/>
        }
      </div>
    </main>
  </div>

</BaseLayout>
