---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import TableOfContents from '../components/TableOfContents.astro';
import { getSections } from '../utils/data';
import { fetchAllSections } from '../utils/sectionMappings';
import { absoluteUrl } from '../utils/urls';

export interface Props {
  title: string;
  lang?: string;
  currentSection?: any;
  useFooter?: boolean;
  sections?: any[];
}

const { title, lang = 'de', currentSection, useFooter=true, sections: providedSections } = Astro.props;

const SITE_DESC = 'Das digitale Handbuch der Schweizer Pfadibewegung';
const siteBase = (Astro.site?.href ?? 'https://thilo.scouts.ch').replace(/\/$/, '');

function extractDescription(md?: string): string {
  if (!md) return SITE_DESC;
  const plain = md
    .replace(/!\[.*?\]\(.*?\)/g, '')
    .replace(/\[([^\]]+)\]\([^)]+\)/g, '$1')
    .replace(/#{1,6}\s+/g, '')
    .replace(/\*\*?(.*?)\*\*?/g, '$1')
    .replace(/`[^`]+`/g, '')
    .replace(/<[^>]+>/g, '')
    .replace(/\s+/g, ' ')
    .trim();
  return plain.length > 155 ? plain.slice(0, 155).trimEnd() + '…' : plain || SITE_DESC;
}

// Strapi can override the extracted values via optional seo_* fields
const description = currentSection?.seo_description || extractDescription(currentSection?.content);
const pageTitle = currentSection?.seo_title ? `${currentSection.seo_title} | Thilo` : title;
const canonicalUrl = `${siteBase}${Astro.url.pathname}`;

let sections: any[] = [];
let allSectionsData: any = null;
try {
  // Fetch all sections data once (includes all locales)
  allSectionsData = await fetchAllSections();
  
  // Use provided sections if available, otherwise extract from allSectionsData
  if (providedSections) {
    sections = providedSections;
  } else if (allSectionsData.sections[lang]) {
    // Convert SimpleSectionsData format to SectionT format
    sections = allSectionsData.sections[lang];
  } else {
    // Fallback to getSections if needed
    sections = await getSections(lang);
  }
} catch (e) {
  console.error('Error loading sections:', e);
  sections = [];
  allSectionsData = { sections: {}, sectionMappings: {} };
}

// Build hreflang alternates
type HreflangEntry = { hreflang: string; url: string };
let hreflangUrls: HreflangEntry[] = [];

const sectionMapping = currentSection
  ? allSectionsData?.sectionMappings?.[currentSection.id.toString()]
  : null;

if (sectionMapping) {
  hreflangUrls = Object.entries(sectionMapping).map(([locale, info]: [string, any]) => ({
    hreflang: locale,
    url: absoluteUrl(info.url),
  }));
  const deUrl = sectionMapping['de']?.url;
  if (deUrl) hreflangUrls.push({ hreflang: 'x-default', url: absoluteUrl(deUrl) });
} else {
  // Non-section pages, or sections not in the mapping (e.g. start-page): derive from URL path
  let basePath = Astro.url.pathname;
  const basePrefix = import.meta.env.BASE_URL.replace(/\/$/, '');
  if (basePrefix && basePath.startsWith(basePrefix)) basePath = basePath.slice(basePrefix.length);
  if (basePath === '/fr' || basePath === '/it') basePath = '/';
  else if (basePath.startsWith('/fr/') || basePath.startsWith('/it/')) basePath = basePath.slice(3);
  if (!basePath.startsWith('/')) basePath = '/' + basePath;

  const lp = (locale: string) => locale === 'de' ? '' : `/${locale}`;
  hreflangUrls = ['de', 'fr', 'it'].map(locale => ({
    hreflang: locale,
    url: absoluteUrl(`${lp(locale)}${basePath}`),
  }));
  hreflangUrls.push({ hreflang: 'x-default', url: absoluteUrl(basePath) });
}

// JSON-LD structured data
const localePrefix = lang === 'de' ? '' : `/${lang}`;
const logoUrl = absoluteUrl('/pwa-512.png');
const publisher = {
  '@type': 'Organization',
  name: 'Pfadibewegung Schweiz',
  logo: { '@type': 'ImageObject', url: logoUrl },
};

let strippedPath = Astro.url.pathname;
{
  const basePrefix = import.meta.env.BASE_URL.replace(/\/$/, '');
  if (basePrefix && strippedPath.startsWith(basePrefix)) strippedPath = strippedPath.slice(basePrefix.length);
  strippedPath = strippedPath.replace(/^\/(fr|it)(?=\/|$)/, '') || '/';
}

const structuredData: object[] = [];
if (strippedPath === '/' || strippedPath === '') {
  structuredData.push({
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'Thilo',
    url: absoluteUrl(`${localePrefix}/`),
    description: SITE_DESC,
    inLanguage: lang,
    publisher,
    potentialAction: {
      '@type': 'SearchAction',
      target: {
        '@type': 'EntryPoint',
        urlTemplate: `${absoluteUrl(`${localePrefix}/search`)}?q={search_term_string}`,
      },
      'query-input': 'required name=search_term_string',
    },
  });
} else if (sectionMapping && currentSection) {
  structuredData.push(
    {
      '@context': 'https://schema.org',
      '@type': 'Article',
      headline: currentSection.title,
      description,
      inLanguage: lang,
      mainEntityOfPage: canonicalUrl,
      image: logoUrl,
      author: publisher,
      publisher,
    },
    {
      '@context': 'https://schema.org',
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Thilo', item: absoluteUrl(`${localePrefix}/`) },
        { '@type': 'ListItem', position: 2, name: currentSection.title, item: canonicalUrl },
      ],
    },
  );
}
---

<BaseLayout title={pageTitle} lang={lang} allSectionsData={allSectionsData} description={description} canonicalUrl={canonicalUrl} hreflangUrls={hreflangUrls} structuredData={structuredData}>
  <Header locale={lang as 'de' | 'fr' | 'it'} currentSection={currentSection} sections={sections} transition:persist />
  
  <div class="flex min-h-[calc(100vh-52px)] w-full max-w-[1400px] mx-auto">
    <!-- Table of Contents Sidebar -->
    <TableOfContents 
      sections={sections} 
      currentSection={currentSection}
      lang={lang}
      transition:persist
    />
    
    <!-- Main Content -->
    <main class="flex-1 overflow-x-hidden min-w-0">
      <div class="px-4 lg:px-10 py-8 max-w-3xl">
        <slot />
        {useFooter &&
          <Footer locale={lang as 'de' | 'fr' | 'it'} currentSection={currentSection} sections={sections} />
        }
      </div>
    </main>
  </div>

</BaseLayout>
