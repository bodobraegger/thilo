---
import MainLayoutWithToC from '../layouts/MainLayoutWithToC.astro';
import { getTranslations } from '../i18n';
import { fetchAllSections } from '../utils/sectionMappings';
import SearchComponent from '../components/Search.tsx';

// Fetch at build/render time (not in getStaticPaths for non-dynamic routes)
const allSectionsData = await fetchAllSections();
const sections = allSectionsData.sections['de'];

const locale = 'de';
const t = getTranslations(locale);
const url = new URL(Astro.request.url);
const initialQuery = url.searchParams.get('q') || '';
---

<MainLayoutWithToC 
  title={t.translation.searchPage.title + " - Thilo"} 
  lang={locale} 
  currentSection={null} 
  useFooter={false} 
  sections={sections}
  allSectionsData={allSectionsData}
>
  <SearchComponent client:only="react" initialQuery={initialQuery} locale={locale} initialSections={sections} />
</MainLayoutWithToC>
