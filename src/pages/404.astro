---
import MainLayoutWithToC from '../layouts/MainLayoutWithToC.astro';
import { fetchAllSections } from '../utils/sectionMappings';

// Fetch at build/render time for non-dynamic routes
const allSectionsData = await fetchAllSections();
---

<MainLayoutWithToC title="Seite nicht gefunden - Thilo" allSectionsData={allSectionsData}>
  <div class="error-page">
    <div class="error-content">
      <h1>404</h1>
      <h2>Seite nicht gefunden</h2>
      <p>Die gesuchte Seite konnte leider nicht gefunden werden.</p>
      <div class="error-actions">
        <a href="/" class="button primary">Zur Startseite</a>
        <a href="/search" class="button secondary">Suche</a>
      </div>
    </div>
  </div>
</MainLayoutWithToC>
