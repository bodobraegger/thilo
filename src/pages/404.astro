---
import MainLayoutWithToC from '../layouts/MainLayoutWithToC.astro';
import AstroLink from '../components/AstroLink.astro';
---

<MainLayoutWithToC title="Seite nicht gefunden | Thilo">
  <div class="error-page">
    <div class="error-content">
      <h1>404</h1>
      <h2>Seite nicht gefunden</h2>
      <p>Die gesuchte Seite konnte leider nicht gefunden werden.</p>
      <div class="error-actions">
        <AstroLink href="/" class="button primary">Zur Startseite</AstroLink>
        <AstroLink href="/search" class="button secondary">Suche</AstroLink>
      </div>
    </div>
  </div>
</MainLayoutWithToC>
