---
import MainLayoutWithToC from '../../layouts/MainLayoutWithToC.astro';
import { getTranslations } from '../../i18n';
import { fetchAllSections } from '../../utils/sectionMappings';
import MarkdownRenderer from '../../components/MarkdownRenderer.tsx';

async function fetchImpressum(locale: string) {
  try {
    const response = await fetch(`https://api.thilo.scouts.ch/impressum-page?locale=${locale}`);
    if (!response.ok) return null;
    const data = await response.json();
    if (data?.data?.attributes) return data.data.attributes;
    if (data?.id) return data;
    return null;
  } catch (error) {
    return null;
  }
}

export async function getStaticPaths() {
  const allSectionsData = await fetchAllSections();
  const locales = ['fr', 'it'];
  
  const paths = [];
  for (const locale of locales) {
    const impressumData = await fetchImpressum(locale);
    paths.push({
      params: { lang: locale },
      props: { allSectionsData, impressumData, locale }
    });
  }
  return paths;
}

const { allSectionsData, impressumData, locale } = Astro.props;
const t = getTranslations(locale as any);
---
<MainLayoutWithToC 
  title={impressumData?.title ? impressumData.title + " - Thilo" : t.translation.header.imprint + " - Thilo"} 
  lang={locale}
  allSectionsData={allSectionsData}
>
  <div class="content">
    <div class="section-title mb-2">
      <h1 class="bg-primary px-2">{impressumData?.title || t.translation.header.imprint}</h1>
    </div>
    
    {impressumData?.content ? (
      <MarkdownRenderer client:load content={impressumData.content} />
    ) : (
      <p>Impressum content not found</p>
    )}
  </div>
</MainLayoutWithToC>
