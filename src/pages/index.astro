---
import SectionPage from '../components/SectionPage.astro';
import { getStartPage } from '../utils/data';
import { fetchAllSections } from '../utils/sectionMappings';
import type { SectionT } from '../utils/data';

const allSectionsData = await fetchAllSections();
const locale = 'de';
const startPage = await getStartPage(locale);

const homepageSection: SectionT = {
  id: startPage.id,
  title: startPage.title,
  content: startPage.content,
  sorting: 0,
  menu_name: startPage.menu_name,
  locale: startPage.locale,
  color_primary: '#521d3a',
  chapters: []
};
---

<SectionPage section={homepageSection} locale={locale} allSectionsData={allSectionsData} />
