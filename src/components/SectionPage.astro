---
import MainLayoutWithToC from '../layouts/MainLayoutWithToC.astro';
import Section from './Section.astro';
import type { SectionT } from "../utils/data";


interface Props {
  section: SectionT;
  locale: string;
  allSectionsData?: any;
}

const { section, locale, allSectionsData } = Astro.props;
---

<MainLayoutWithToC 
  title={section.title} 
  lang={locale} 
  currentSection={section}
  allSectionsData={allSectionsData}
>
  <Section section={section} />
</MainLayoutWithToC>
