---
import MainLayoutWithToC from '../layouts/MainLayoutWithToC.astro';
import Section from './Section.astro';
import type { SectionT } from "../utils/data";


interface Props {
  section: SectionT;
  locale: string;
  isIndex?: boolean;
}

const { section, locale, isIndex = false } = Astro.props;

if (!section) {
  return Astro.redirect('/404');
}
---

<MainLayoutWithToC title={isIndex ? section.title : section.title + ' | Thilo'} lang={locale} currentSection={section}>
  <Section section={section} />
</MainLayoutWithToC>
