---
import { getTranslations, type Locale } from '../i18n';
import { fetchAllSections, getSectionUrlForLocaleFromCache, type SimpleSectionsData } from '../utils/sectionMappings';
import AstroLink from './AstroLink.astro';
import SearchComponent from './Search.astro';

interface Props {
  locale?: Locale;
  currentSection?: any;
  sections?: any[];
}

const { locale = 'de', currentSection, sections = [] } = Astro.props;
const t = getTranslations(locale);


// Get current URL to determine page type
const url = Astro.url;
const pathname = url.pathname;
const isSearchPage = pathname === '/search' || pathname.endsWith('/search') || pathname.endsWith('/search/');

// Fetch ALL section data at build time
const allSectionsData: SimpleSectionsData = await fetchAllSections();

// Generate language alternatives for dropdown
let languageAlternatives = [];

if (currentSection) {
  // For section pages, use pre-built section mapping
  for (const targetLocale of ['de', 'fr', 'it']) {
    if (targetLocale === locale) continue; // Skip current locale
    
    const url = getSectionUrlForLocaleFromCache(
      currentSection.id.toString(), 
      targetLocale, 
      allSectionsData.sectionMappings
    );
    languageAlternatives.push({ locale: targetLocale, url });
  }
} else {
  // For other pages (index, search, etc.), determine equivalent URLs
  let basePath = pathname;
  
  // Remove locale prefix if present
  if (pathname.startsWith('/fr/')) {
    basePath = pathname.substring(3) || '/';
  } else if (pathname.startsWith('/it/')) {
    basePath = pathname.substring(3) || '/';
  }
  
  // Ensure basePath starts with /
  if (!basePath.startsWith('/')) {
    basePath = '/' + basePath;
  }
  
  // Generate URLs for all locales
  for (const targetLocale of ['de', 'fr', 'it']) {
    if (targetLocale === locale) continue; // Skip current locale
    
    let targetUrl;
    if (targetLocale === 'de') {
      targetUrl = basePath === '/' ? '/' : basePath;
    } else {
      targetUrl = basePath === '/' ? `/${targetLocale}/` : `/${targetLocale}${basePath}`;
    }
    languageAlternatives.push({ locale: targetLocale, url: targetUrl });
  }
}
---

<!-- Redesigned Header -->
<header>
  <div class="max-w-[1400px] mx-auto flex items-center">

    <!-- Mirrors sidebar width (w-72 = 288px on desktop, just holds burger on mobile) -->
    <div class="shrink-0 lg:w-72 pl-4 lg:px-0 flex items-center">
      <button 
        type="button"
        id="sidebar-toggle-header"
        class="lg:hidden p-1.5 rounded-md transition-colors bg-white text-gray-700 hover:bg-gray-50 hover:text-gray-900"
        aria-label="Toggle sidebar"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>

    <!-- Mirrors <main class="flex-1"> exactly -->
    <div class="flex-1 flex items-center min-w-0">
      <!-- Mirrors <div class="px-4 lg:px-10 max-w-3xl"> — padding and max-width are on the SAME element -->
      <div class="flex-1 min-w-0 px-4 lg:px-10 max-w-3xl">
        <div class="hidden lg:block">
          <SearchComponent locale={locale} inline={true} noDropdown={isSearchPage} initialSections={sections} />
        </div>
        <div class="lg:hidden w-full">
          <SearchComponent locale={locale} inline={true} isMobile={true} noDropdown={isSearchPage} initialSections={sections} />
        </div>
      </div>

      <!-- Menu button sits outside the content area, with its own right padding -->
      <div class="flex items-center shrink-0 pr-4 lg:pr-4">
        <div class="relative">
          <!-- Menu dropdown toggle -->
          <button 
            type="button"
            id="menu-dropdown-toggle"
            class="p-1.5 rounded-md transition-colors bg-white text-gray-700 hover:bg-gray-50 hover:text-gray-900"
            aria-label="Open menu"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h.01M12 12h.01M19 12h.01M6 12a1 1 0 11-2 0 1 1 0 012 0zm7 0a1 1 0 11-2 0 1 1 0 012 0zm7 0a1 1 0 11-2 0 1 1 0 012 0z" />
            </svg>
          </button>

          <!-- Dropdown menu -->
          <div 
            id="menu-dropdown" 
            class="hidden absolute right-0 xl:left-0 mt-2 w-56 bg-white rounded-md shadow-lg border border-gray-200 py-1 z-50"
          >
            <div class="px-4 py-2 border-b border-gray-200">
              <p class="text-xs font-medium text-gray-500 uppercase tracking-wider mb-2">
                Language
              </p>
              
              <!-- Language Options -->
              <button 
                type="button"
                class="w-full text-left flex items-center px-4 py-2 text-sm transition-colors text-gray-700 hover:bg-gray-100 hover:text-gray-900 language-option"
                data-locale="de"
              >
                <span class="mr-2">{locale === 'de' ? '✓' : ''}</span>
                <span>Deutsch</span>
              </button>
              <button 
                type="button"
                class="w-full text-left flex items-center px-4 py-2 text-sm transition-colors text-gray-700 hover:bg-gray-100 hover:text-gray-900 language-option"
                data-locale="fr"
              >
                <span class="mr-2">{locale === 'fr' ? '✓' : ''}</span>
                <span>Français</span>
              </button>
              <button 
                type="button"
                class="w-full text-left flex items-center px-4 py-2 text-sm transition-colors text-gray-700 hover:bg-gray-100 hover:text-gray-900 language-option"
                data-locale="it"
              >
                <span class="mr-2">{locale === 'it' ? '✓' : ''}</span>
                <span>Italiano</span>
              </button>
              
              <!-- Theme Section -->
              <div class="border-t border-gray-200 mt-1">
                <button 
                  type="button"
                  id="theme-toggle"
                  class="w-full text-left block px-4 py-2 text-sm transition-colors text-gray-700 hover:bg-gray-100 hover:text-gray-900"
                >
                  <span class="flex items-center justify-between">
                    <span>Theme</span>
                    <span class="text-xs text-gray-500">Hell</span>
                  </span>
                </button>
              </div>
              
              <!-- Impressum Section -->
              <div class="border-t border-gray-200">
                <AstroLink 
                  href={locale === 'de' ? '/impressum' : `/${locale}/impressum`}
                  class="block px-4 py-2 text-sm transition-colors text-gray-700 hover:bg-gray-100 hover:text-gray-900"
                >
                  {t.translation.header.imprint}
                </AstroLink>
              </div>
            </div>
          </div>
        </div><!-- end relative -->
        </div><!-- end menu button -->
      </div><!-- end flex-1 main mirror -->

  </div><!-- end max-w-[1400px] -->
</header>

<style>
  /* Prevent double-tap zoom and remove 300ms click delay on all interactive header elements */
  header button,
  header a,
  header input {
    touch-action: manipulation;
  }
</style>

<script is:inline>
  (function () {
    var q = new URLSearchParams(location.search).get('q');
    if (!q) return;
    // Populate SSR-rendered search inputs immediately, before React hydrates
    document.querySelectorAll('header input[type="text"]').forEach(function (el) {
      el.value = q;
    });
  })();
</script>

<script is:inline define:vars={{ base: import.meta.env.BASE_URL.replace(/\/$/, '') }}>
(function () {
  // AbortController pattern: abort old listeners before each swap, re-attach after.
  // window.__headerController persists across is:inline re-executions so abort() reaches
  // the listeners from the previous run.
  function setup() {
    window.__headerController?.abort();
    window.__headerController = new AbortController();
    const { signal } = window.__headerController;

    const sidebarToggleHeader = document.getElementById('sidebar-toggle-header');
    const menuDropdownToggle  = document.getElementById('menu-dropdown-toggle');
    const menuDropdown        = document.getElementById('menu-dropdown');
    const themeToggle         = document.getElementById('theme-toggle');

    function openMenu()  { menuDropdown?.classList.remove('hidden'); }
    function closeMenu() { menuDropdown?.classList.add('hidden'); }
    function buildUrl(path) { return base + path; }

    sidebarToggleHeader?.addEventListener('click', () => {
      window.dispatchEvent(new CustomEvent('toggleSidebar'));
    }, { signal });

    menuDropdownToggle?.addEventListener('click', (e) => {
      e.stopPropagation();
      menuDropdown?.classList.contains('hidden') ? openMenu() : closeMenu();
    }, { signal });

    document.addEventListener('click', (e) => {
      if (menuDropdown && !menuDropdown.classList.contains('hidden')) {
        if (!menuDropdown.contains(e.target) && !menuDropdownToggle?.contains(e.target)) {
          closeMenu();
        }
      }
    }, { signal });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !menuDropdown?.classList.contains('hidden')) closeMenu();
    }, { signal });

    themeToggle?.addEventListener('click', () => closeMenu(), { signal });

    document.querySelectorAll('.language-option').forEach(option => {
      option.addEventListener('click', (e) => {
        const selectedLocale = e.currentTarget?.dataset?.locale;
        const currentLocale  = document.documentElement.lang || 'de';
        if (!selectedLocale || selectedLocale === currentLocale) { closeMenu(); return; }
        handleLanguageChange(selectedLocale);
        closeMenu();
      }, { signal });
    });

    function handleLanguageChange(targetLocale) {
      const currentHash = window.location.hash;
      let path = window.location.pathname;
      if (base && path.startsWith(base)) path = path.slice(base.length);
      path = path.replace(/^\/|\/$/g, '');
      if (path.startsWith('fr/'))      path = path.substring(3);
      else if (path.startsWith('it/')) path = path.substring(3);
      else if (path === 'fr' || path === 'it') path = '';

      if (path === 'impressum') {
        window.location.href = targetLocale === 'de' ? buildUrl('/impressum') : buildUrl(`/${targetLocale}/impressum`);
        return;
      }

      const allSectionsMeta = document.querySelector('meta[name="all-sections"]')?.getAttribute('content');
      if (!allSectionsMeta) {
        window.location.href = targetLocale === 'de' ? buildUrl('/') : buildUrl(`/${targetLocale}/`);
        return;
      }

      const allSections    = JSON.parse(allSectionsMeta);
      const currentLocale  = document.documentElement.lang || 'de';
      const currentSection = (allSections[currentLocale] || []).find(s => s.slug === path);

      if (currentSection) {
        const targetSection = (allSections[targetLocale] || []).find(s => s.sorting === currentSection.sorting);
        if (targetSection) {
          const targetUrl = buildUrl(targetLocale === 'de' ? `/${targetSection.slug}` : `/${targetLocale}/${targetSection.slug}`);
          if (currentHash && currentSection.chapters && targetSection.chapters) {
            const curChapter = currentSection.chapters.find(c => c.slug === currentHash.slice(1));
            if (curChapter) {
              const tgtChapter = targetSection.chapters.find(c => c.sorting === curChapter.sorting);
              if (tgtChapter) { window.location.href = targetUrl + `#${tgtChapter.slug}`; return; }
            }
          }
          window.location.href = targetUrl;
          return;
        }
      }

      let targetUrl = path === 'search'
        ? (targetLocale === 'de' ? buildUrl('/search') : buildUrl(`/${targetLocale}/search`))
        : (targetLocale === 'de' ? buildUrl('/') : buildUrl(`/${targetLocale}/`));
      if (window.location.search) targetUrl += window.location.search;
      window.location.href = targetUrl;
    }
  }

  // Register the astro:page-load listener only once — it persists on window across navigations.
  if (!window.__headerDocListeners) {
    window.__headerDocListeners = true;
    document.addEventListener('astro:page-load', setup);
  }

  // Also run immediately: handles the initial page load before astro:page-load fires,
  // and re-runs setup when the is:inline script re-executes on each navigation
  // (abort() at the top of setup() cleans up the previous run's listeners).
  setup();
})();
</script>
