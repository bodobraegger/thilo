---
import QuizComponent from "./Quiz";
import AstroLink from "./AstroLink.astro";
import type { SectionT } from "../utils/data";
import { getTranslations, type Locale } from "../i18n";
import { renderMarkdownParts } from "../utils/markdown";

import "../styles/quiz.css";
import "../styles/section.css";

export interface Props {
    section: SectionT;
    lang?: string;
    isIndex?: boolean;
}

const { section, lang = "de", isIndex = false } = Astro.props;
const t = getTranslations(lang as Locale);
const base = import.meta.env.BASE_URL.replace(/\/$/, "");

const render = (content?: string) =>
    content ? renderMarkdownParts(content, base, lang) : [];

const sectionParts = render(section.content);

// Get section color for CSS variable
const sectionColor = section.color_primary || "#521d3a";
---

<section class="content" data-color={sectionColor}>
    {
        !isIndex && (
            <nav class="text-sm text-gray-500 mb-4" aria-label="Breadcrumb">
                <AstroLink href={lang === "de" ? "/" : `/${lang}/`} class="hover:underline">
                    {t.translation.homePage.title}
                </AstroLink>
                <span class="mx-1" aria-hidden="true">›</span>
                <span class="text-gray-700">{section.menu_name || section.title}</span>
            </nav>
        )
    }
    <div
        id="section-title"
        class={`section-title section-${section.sorting} mb-4`}
    >
        <h1 class="bg-primary px-2">
            {section.title}
        </h1>
        {
            section.icon && (
                <img class="icon pl-2" src={section.icon.url} alt={section.icon.alternativeText || ""} />
            )
        }
    </div>
    {
        sectionParts.length > 0 && (
            <div class="section-body rounded-md p-4 color-bg-default">
                <div class="section-description markdown-content">
                    {sectionParts.map((part) =>
                        part.type === "quiz" ? (
                            <QuizComponent url={part.value} strings={t.translation.quiz} client:visible />
                        ) : (
                            <div set:html={part.value} />
                        )
                    )}
                </div>
            </div>
        )
    }
    {
        section.chapters && section.chapters.length > 0 && (
            <div class="chapters">
                {section.chapters
                    .sort((a, b) => (a.sorting || 0) - (b.sorting || 0))
                    .map((chapter) => (
                        <div id={chapter.slug} class="chapter">
                            <h2>{chapter.title}</h2>
                            <div class="chapter-content markdown-content">
                                {render(chapter.content).map((part) =>
                                    part.type === "quiz" ? (
                                        <QuizComponent url={part.value} strings={t.translation.quiz} client:visible />
                                    ) : (
                                        <div set:html={part.value} />
                                    )
                                )}
                            </div>
                            {chapter.targets && chapter.targets.length > 0 && (
                                <div class="targets">
                                    <h3>{t.translation.section.targetGroup}</h3>
                                    <div class="targets-list">
                                        {chapter.targets.map((target) => (
                                            <div class="target-item">
                                                <span class="target-role">
                                                    {target.role}
                                                </span>
                                                <h4>{target.title}</h4>
                                                <div class="markdown-content">
                                                    {render(target.content).map((part) =>
                                                        part.type === "quiz" ? (
                                                            <QuizComponent url={part.value} strings={t.translation.quiz} client:visible />
                                                        ) : (
                                                            <div set:html={part.value} />
                                                        )
                                                    )}
                                                </div>
                                            </div>
                                        ))}
                                    </div>
                                </div>
                            )}
                        </div>
                    ))}
            </div>
        )
    }

    <!-- Back to top button -->
    <button
        id="back-to-top"
        class="opacity-0 pointer-events-none fixed bottom-4 right-4 h-10 w-10 rounded-full bg-primary text-white shadow-lg hover:bg-primary-hover focus:outline-none focus:ring-2 focus:ring-primary-500 transition-[opacity,transform] duration-300 active:scale-[0.96] z-50"
        onclick="document.getElementById('section-title')?.scrollIntoView({behavior: 'smooth'})"
        aria-label={t.translation.section.backToTop}
    >
        <svg
            aria-hidden="true"
            focusable="false"
            class="octicon octicon-move-to-top m-auto"
            viewBox="0 0 16 16"
            width="16"
            height="16"
            fill="currentColor"
            ><path
                d="M3 2.25a.75.75 0 0 1 .75-.75h8.5a.75.75 0 0 1 0 1.5h-8.5A.75.75 0 0 1 3 2.25Zm5.53 2.97 3.75 3.75a.749.749 0 1 1-1.06 1.06L8.75 7.561v6.689a.75.75 0 0 1-1.5 0V7.561L4.78 10.03a.749.749 0 1 1-1.06-1.06l3.75-3.75a.749.749 0 0 1 1.06 0Z"
            ></path></svg
        >
    </button>
</section>
